# =============================================================================
# QUANTA BOT — .gitignore
# =============================================================================

# ---- Secrets & Environment ----
.env
.env.*
*.key
*.pem

# ---- Runtime Artifacts (SQLite DBs, JSON state, logs) ----
Quanta-bot/runtime/
runtime/

# ---- Python ----
__pycache__/
*.py[cod]
*$py.class
*.so

# ---- Pytest ----
.pytest_cache/
.cache/
htmlcov/
.coverage
*.cover

# ---- IDE / Editor ----
.vscode/
.idea/
*.swp
*.swo
*~

# ---- Research Data & Results (Whitelisted) ----
research/historical_data/
research/backtest_results*/
research/edge_strength_results/
research/backtest_results_v2/
research/backtest_results_v3/
research/portfolio_backtests/
*.sqlite
*.csv

# ---- OS ----
.DS_Store
Thumbs.db
desktop.ini
